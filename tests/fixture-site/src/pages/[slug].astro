---
import { getEmDashEntry, type PortableTextBlock } from "emdash";
import { PortableText } from "emdash/ui";

const { slug } = Astro.params;
const { entry: page } = await getEmDashEntry("pages", slug ?? "");

if (!page) {
	Astro.response.status = 404;
}
const content = page?.data.content as PortableTextBlock[] | undefined;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>Dinkus blocks fixture</title>
	</head>
	<body>
		<main>
			{
				content ? (
					<PortableText value={content} />
				) : (
					<p data-fixture-empty>This fixture page has no published content.</p>
				)
			}
		</main>
	</body>
</html>

<style is:global>
	:root {
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
			sans-serif;
		color: #1e293b;
		background: #f8fafc;
	}

	body {
		margin: 0;
	}

	main {
		width: min(68rem, calc(100% - 2rem));
		margin: 0 auto;
		padding: 4rem 0;
	}
</style>
