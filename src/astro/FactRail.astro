---
import type { FactItem, FactRailNode } from "../types";

interface Props {
	node: FactRailNode;
}

const { node } = Astro.props;
const facts = (Array.isArray(node.facts) ? node.facts : []).filter(
	(fact): fact is FactItem =>
		Boolean(fact && typeof fact === "object" && (fact.label || fact.value)),
);
---

{
	facts.length > 0 && (
		<dl
			class="dinkus-fact-rail"
			data-dinkus-block="fact-rail"
			tabindex="0"
			aria-label={node.ariaLabel || "Quick facts"}
		>
			{facts.map((fact) => (
				<div class="dinkus-fact-rail__fact" data-dinkus-icon={fact.icon || undefined}>
					{fact.label && <dt>{fact.label}</dt>}
					{fact.value && <dd>{fact.value}</dd>}
				</div>
			))}
		</dl>
	)
}

<style>
	.dinkus-fact-rail {
		display: flex;
		gap: 1rem;
		margin: 1.5rem 0;
		padding: 0.25rem;
		overflow-x: auto;
	}

	.dinkus-fact-rail__fact {
		flex: none;
		min-width: 9rem;
		padding: 0.75rem 1rem;
		border: 1px solid color-mix(in srgb, currentColor 20%, transparent);
		border-radius: 0.75rem;
		background: color-mix(in srgb, currentColor 4%, transparent);
	}

	dt {
		margin: 0 0 0.25rem;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		opacity: 0.7;
	}

	dd {
		margin: 0;
		font-weight: 600;
	}
</style>
