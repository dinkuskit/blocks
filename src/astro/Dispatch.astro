---
import type { DispatchNode } from "../types";
import { safeCtaHref } from "../links";

interface Props {
	node: DispatchNode;
}

const { node } = Astro.props;
const ctaHref = safeCtaHref(node.ctaHref);
const showCta = Boolean(node.ctaLabel && ctaHref);
const phoneHref = safeCtaHref(node.phone);
const emailHref = safeCtaHref(node.email);
const hasContact = Boolean(phoneHref || emailHref);
---

<section class="dinkus-dispatch" data-dinkus-block="dispatch">
	<div class="dinkus-dispatch__copy">
		{node.kicker && <p class="dinkus-dispatch__kicker">{node.kicker}</p>}
		{node.title && <h2>{node.title}</h2>}
		{node.body && <p class="dinkus-dispatch__body">{node.body}</p>}
		{
			hasContact && (
				<p class="dinkus-dispatch__contact">
					{phoneHref && (
						<a class="dinkus-dispatch__contact-link" href={phoneHref}>
							{node.phone}
						</a>
					)}
					{emailHref && (
						<a class="dinkus-dispatch__contact-link" href={emailHref}>
							{node.email}
						</a>
					)}
				</p>
			)
		}
	</div>
	{
		showCta && (
			<a class="dinkus-dispatch__action" href={ctaHref}>
				{node.ctaLabel}
			</a>
		)
	}
</section>

<style>
	@layer dinkus-blocks {
	.dinkus-dispatch {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--dinkus-content-gap, 2rem);
		padding: var(--dinkus-panel-padding, clamp(1.5rem, 4vw, 3rem));
		border-top: var(
			--dinkus-panel-border,
			1px solid color-mix(in srgb, currentColor 20%, transparent)
		);
	}

	.dinkus-dispatch__copy {
		max-width: var(--dinkus-copy-max-width, 48rem);
	}

	.dinkus-dispatch__kicker {
		margin: 0 0 0.5rem;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	h2 {
		margin: 0;
	}

	.dinkus-dispatch__body {
		margin: 0.75rem 0 0;
		line-height: 1.6;
	}

	.dinkus-dispatch__contact {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		margin: 0.75rem 0 0;
	}

	.dinkus-dispatch__contact-link {
		font-weight: 600;
		text-decoration: none;
	}

	.dinkus-dispatch__action {
		flex: none;
		padding: 0.75rem 1rem;
		border-radius: var(--dinkus-action-radius, 999px);
		background: var(--dinkus-action-background, CanvasText);
		color: var(--dinkus-action-color, Canvas);
		font-weight: 700;
		text-decoration: none;
	}

	@media (max-width: 40rem) {
		.dinkus-dispatch {
			align-items: flex-start;
			flex-direction: column;
		}
	}
	}
</style>
