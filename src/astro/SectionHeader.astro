---
import type { SectionHeaderNode } from "../types";

interface Props {
	node: SectionHeaderNode;
}

const { node } = Astro.props;
---

<header class="dinkus-section-header" data-dinkus-block="section-header">
	{
		(node.number || node.kicker) && (
			<p class="dinkus-section-header__meta">
				{node.number && (
					<span class="dinkus-section-header__number" aria-hidden="true">
						{node.number}
					</span>
				)}
				{node.kicker && <span class="dinkus-section-header__kicker">{node.kicker}</span>}
			</p>
		)
	}
	<div class="dinkus-section-header__title-wrap">
		{node.title && <h2>{node.title}</h2>}
		{node.intro && <p class="dinkus-section-header__intro">{node.intro}</p>}
	</div>
</header>

<style>
	@layer dinkus-blocks {
	.dinkus-section-header {
		display: grid;
		gap: var(--dinkus-item-gap, 0.75rem);
		margin: var(--dinkus-section-spacing, clamp(1.5rem, 4vw, 3rem)) 0 1.5rem;
	}

	.dinkus-section-header__meta {
		display: flex;
		align-items: baseline;
		gap: var(--dinkus-item-gap, 0.75rem);
		margin: 0;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.dinkus-section-header__number {
		opacity: var(--dinkus-muted-opacity, 0.5);
	}

	h2 {
		margin: 0;
		font-size: var(--dinkus-title-size, clamp(1.5rem, 3.5vw, 2.25rem));
		line-height: var(--dinkus-title-line-height, 1.2);
	}

	.dinkus-section-header__intro {
		margin: 0.5rem 0 0;
		max-width: var(--dinkus-copy-max-width, 44rem);
		line-height: 1.6;
	}
	}
</style>
