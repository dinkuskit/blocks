---
import type { LegendEntry, ServiceAreaMapNode } from "../types";

interface Props {
	node: ServiceAreaMapNode;
}

const { node } = Astro.props;
const legend = (Array.isArray(node.legend) ? node.legend : []).filter(
	(entry): entry is LegendEntry =>
		Boolean(entry && typeof entry === "object" && entry.label),
);
---

<section class="dinkus-service-area-map" data-dinkus-block="service-area-map">
	<figure class="dinkus-service-area-map__figure">
		{
			node.image ? (
				<img
					class="dinkus-service-area-map__img"
					src={node.image}
					alt={node.imageAlt ?? ""}
					loading="lazy"
					decoding="async"
				/>
			) : (
				<div class="dinkus-service-area-map__placeholder" aria-hidden="true" />
			)
		}
		{
			node.caption && (
				<figcaption class="dinkus-service-area-map__caption">
					{node.caption}
				</figcaption>
			)
		}
	</figure>
	{
		legend.length > 0 && (
			<ul class="dinkus-service-area-map__legend">
				{legend.map((entry) => (
					<li data-dinkus-icon={entry.icon || undefined}>{entry.label}</li>
				))}
			</ul>
		)
	}
</section>

<style>
	.dinkus-service-area-map {
		display: grid;
		grid-template-columns: 2fr 1fr;
		gap: 1.5rem;
		align-items: start;
		margin: clamp(1.5rem, 4vw, 3rem) 0;
	}

	@media (max-width: 56rem) {
		.dinkus-service-area-map {
			grid-template-columns: 1fr;
		}
	}

	.dinkus-service-area-map__figure {
		margin: 0;
	}

	.dinkus-service-area-map__img,
	.dinkus-service-area-map__placeholder {
		width: 100%;
		border-radius: 0.5rem;
		border: 1px solid color-mix(in srgb, currentColor 20%, transparent);
	}

	.dinkus-service-area-map__placeholder {
		aspect-ratio: 9 / 7;
		background: color-mix(in srgb, currentColor 6%, transparent);
	}

	.dinkus-service-area-map__caption {
		margin-top: 0.75rem;
		font-size: 0.85rem;
		line-height: 1.5;
		opacity: 0.75;
	}

	.dinkus-service-area-map__legend {
		list-style: none;
		display: grid;
		gap: 0.6rem;
		margin: 0;
		padding: 1rem 1.25rem;
		border: 1px solid color-mix(in srgb, currentColor 20%, transparent);
		border-radius: 0.75rem;
		background: color-mix(in srgb, currentColor 4%, transparent);
	}
</style>
