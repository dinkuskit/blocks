---
import { safeCtaHref } from "../links";

interface SearchLink {
	label?: string;
	href?: string;
}

interface Props {
	node: {
		_type?: string;
		_key?: string;
		number?: string;
		kicker?: string;
		title?: string;
		intro?: string;
		links?: SearchLink[];
	};
}

const { node } = Astro.props;
const links = (Array.isArray(node.links) ? node.links : [])
	.map((link) => ({ ...link, href: safeCtaHref(link?.href) }))
	.filter((link): link is { label: string; href: string } =>
		Boolean(link.label && link.href),
	);
---

<section class="dinkus-search-board" data-dinkus-block="search-board">
	{
		(node.number || node.kicker || node.title || node.intro) && (
			<header class="dinkus-search-board__header">
				{(node.number || node.kicker) && (
					<p class="dinkus-search-board__meta">
						{node.number && (
							<span
								class="dinkus-search-board__number"
								aria-hidden="true"
							>
								{node.number}
							</span>
						)}
						{node.kicker && (
							<span class="dinkus-search-board__kicker">{node.kicker}</span>
						)}
					</p>
				)}
				{node.title && <h2>{node.title}</h2>}
				{node.intro && (
					<p class="dinkus-search-board__intro">{node.intro}</p>
				)}
			</header>
		)
	}
	{
		links.length > 0 && (
			<ul class="dinkus-search-board__list">
				{links.map((link) => (
					<li>
						<a href={link.href}>{link.label}</a>
					</li>
				))}
			</ul>
		)
	}
</section>

<style>
	.dinkus-search-board {
		margin: clamp(1.5rem, 4vw, 3rem) 0;
	}

	.dinkus-search-board__meta {
		display: flex;
		align-items: baseline;
		gap: 0.75rem;
		margin: 0 0 0.5rem;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.dinkus-search-board__number {
		opacity: 0.5;
	}

	h2 {
		margin: 0;
		font-size: clamp(1.5rem, 3.5vw, 2.25rem);
		line-height: 1.2;
	}

	.dinkus-search-board__intro {
		margin: 0.5rem 0 0;
		max-width: 44rem;
		line-height: 1.6;
	}

	.dinkus-search-board__list {
		list-style: none;
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
		gap: 0.5rem 1.5rem;
		margin: 1.5rem 0 0;
		padding: 0;
	}

	.dinkus-search-board__list a {
		font-weight: 600;
		text-decoration: none;
	}

	.dinkus-search-board__list a:hover {
		text-decoration: underline;
	}
</style>
