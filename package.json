{
  "name": "@dinkuskit/blocks",
  "version": "0.0.0",
  "description": "Section blocks for EmDash sites",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./astro": "./src/astro/index.ts"
  },
  "files": [
    "src",
    "patterns",
    "docs/architecture.md",
    "COMPAT.md",
    "ROADMAP.md",
    "CONTRIBUTING.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit && pnpm --dir tests/fixture-site typecheck",
    "test": "vitest run",
    "build:fixture": "pnpm --dir tests/fixture-site build",
    "test:e2e": "node scripts/run-e2e.mjs",
    "check:pack": "node scripts/check-pack.mjs",
    "check": "pnpm typecheck && pnpm test && pnpm build:fixture && pnpm check:pack"
  },
  "peerDependencies": {
    "astro": ">=7.0.0 <8.0.0",
    "emdash": "0.29.0"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@11.9.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dinkuskit/blocks.git"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "astro": "7.1.3",
    "emdash": "0.29.0",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "@emdash-cms/blocks": "0.29.0"
  }
}
